<?xml version="1.0" encoding="utf-8"?>
<experiments>
  <experiment name="2 гипотеза" repetitions="30" sequentialRunOrder="true" version="NetLogo 7.0.4" runMetricsEveryStep="false" timeLimit="1000">
    <setup>setup</setup>
    <go>go</go>
    <metrics>
      <metric>total-food-count</metric>
      <metric>count turtles</metric>
      <metric>[length my-memory] of turtles</metric>
    </metrics>
    <constants>
      <enumeratedValueSet variable="use-memory?">
        <value value="true"></value>
      </enumeratedValueSet>
      <enumeratedValueSet variable="evaporation-rate">
        <value value="10"></value>
      </enumeratedValueSet>
      <enumeratedValueSet variable="diffusion-rate">
        <value value="50"></value>
      </enumeratedValueSet>
      <enumeratedValueSet variable="more-food?">
        <value value="false"></value>
        <value value="true"></value>
      </enumeratedValueSet>
    </constants>
  </experiment>
</experiments>
